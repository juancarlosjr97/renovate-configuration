{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "autoApprove": true,
    "automerge": true,
    "commitBodyTable": true,
    "customManagers": [
        {
            "customType": "regex",
            "datasourceTemplate": "github-releases",
            "depNameTemplate": "juancarlosjr97/renovate-configuration",
            "fileMatch": [
                "^renovate\\.json5?$",
                "^\\.github/renovate\\.json5?$",
                "^\\.gitlab/renovate\\.json5?$",
                "^\\.renovaterc\\.json$",
                "^\\.renovaterc$"
            ],
            "matchStrings": [
                "\"github>juancarlosjr97/renovate-configuration#(?<currentValue>[^\" \\n\\(]+)",
                "\"github>juancarlosjr97/renovate-configuration:.*#(?<currentValue>[^\" \\n\\(]+)",
                "\"github>juancarlosjr97/renovate-configuration/.*#(?<currentValue>[^\" \\n\\(]+)"
            ]
        }
    ],
    "dependencyDashboardOSVVulnerabilitySummary": "all",
    "extends": [
        ":configMigration",
        ":enablePreCommit",
        ":semanticCommits",
        ":semanticPrefixChore",
        "config:best-practices",
        "group:all"
    ],
    "osvVulnerabilityAlerts": true,
    "packageRules": [
        {
            "description": "Keep internal shared-tooling references pinned to main and block Renovate churn between internal tooling repositories",
            "matchPackageNames": [
                "juancarlosjr97/pre-commit-to-rule-them-all",
                "juancarlosjr97/github-actions-workflows-to-rule-them-all",
                "juancarlosjr97/release-it-containerized",
                "juancarlosjr97/renovate-configuration"
            ],
            "enabled": false
        },
        {
            "description": "Pin actions/checkout to v5 until container actions support v6 credential storage",
            "matchPackageNames": [
                "actions/checkout"
            ],
            "allowedVersions": "<6.0.0"
        }
    ],
    "platformAutomerge": true
}
